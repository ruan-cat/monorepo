{
	"name": "@ruan-cat/utils",
	"version": "4.23.0",
	"description": "阮喵喵工具集合。默认提供js文件，也直接提供ts文件。",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"bin": {
		"ruan-cat-utils": "./dist/cli/index.js",
		"move-vercel-output-to-root": "./dist/cli/move-vercel-output-to-root.js",
		"relizy-runner": "./dist/cli/relizy-runner.js"
	},
	"homepage": "https://utils.ruancat6312.top",
	"bugs": {
		"url": "https://github.com/ruan-cat/monorepo/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ruan-cat/monorepo.git",
		"directory": "packages/utils"
	},
	"scripts": {
		"build": "tsup",
		"prebuild": "automd",
		"move-vercel-output-to-root": "tsx ./src/node-esm/scripts/move-vercel-output-to-root/index.ts",
		"docs:dev": "turbo docs:dev",
		"build:docs": "turbo do-build-docs",
		"typedoc": "typedoc --options typedoc.config.mjs",
		"docs:dev-main": "vitepress dev src --port 8080",
		"build:docs-main": "vitepress build src",
		"clean:type": "rimraf dist",
		"generate:type-1": "vue-tsc -p tsconfig.json --composite false --declaration true --emitDeclarationOnly true",
		"generate:type-2": "tsc -p tsconfig.json --composite false --declaration true --emitDeclarationOnly true",
		"generate:type-3": "vue-tsc -p tsconfig.types.json",
		"get-type": "pnpm clean:type && pnpm generate:type-3",
		"build:-try-1": "pnpm clean:type && vue-tsc -p tsconfig.build.json"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./node-cjs": {
			"types": "./dist/node-cjs/index.d.cts",
			"import": "./src/node-cjs/index.ts",
			"require": "./dist/node-cjs/index.cjs"
		},
		"./node-esm": {
			"types": "./dist/node-esm/index.d.ts",
			"import": "./dist/node-esm/index.js"
		},
		"./monorepo": "./src/monorepo/index.ts",
		"./unplugin-vue-router": "./src/unplugin-vue-router/index.ts",
		"./vite-plugin-autogeneration-import-file": "./src/vite-plugin-autogeneration-import-file/index.ts",
		"./vueuse": "./src/vueuse/index.ts",
		"./vueuse/*": "./src/vueuse/*",
		"./src/*": "./src/*",
		"./dist/*": "./dist/*"
	},
	"keywords": [
		"utils"
	],
	"author": {
		"name": "ruan-cat",
		"email": "1219043956@qq.com",
		"url": "https://github.com/ruan-cat"
	},
	"license": "MIT",
	"publishConfig": {
		"access": "public",
		"registry": "https://registry.npmjs.org/",
		"tag": "beta"
	},
	"files": [
		"!**/.vercel/**",
		"!**/.vitepress/**",
		"src",
		"dist/**",
		"tsconfig.json",
		"README.md",
		"!src/**/docs/**",
		"!src/**/tests/**",
		"!*.test.*",
		"!src/**/*.md",
		"!src/typedoc-md/**/*"
	],
	"dependencies": {
		"@vueuse/integrations": "^13.9.0",
		"axios": "^1.13.6",
		"consola": "^3.4.2",
		"lodash-es": "^4.17.23",
		"pkg-types": "^2.3.0",
		"pnpm-workspace-yaml": "^1.6.0",
		"tinyglobby": "^0.2.15"
	},
	"devDependencies": {
		"@antfu/utils": "^9.3.0",
		"@types/js-yaml": "^4.0.9",
		"@types/lodash-es": "^4.17.12",
		"@types/node": "^22.19.15",
		"@types/qs": "^6.15.0",
		"automd": "^0.4.3",
		"commander": "^13.1.0",
		"js-yaml": "^4.1.1",
		"qs": "^6.15.0",
		"tsup": "^8.5.1",
		"type-plus": "^7.6.2",
		"typedoc": "^0.28.17",
		"typedoc-plugin-frontmatter": "^1.3.1",
		"typedoc-plugin-markdown": "^4.10.0",
		"typescript": "^5.9.3",
		"unplugin-auto-import": "^21.0.0",
		"unplugin-vue-router": "^0.16.1",
		"vite-plugin-autogeneration-import-file": "^3.0.1",
		"vitepress": "^1.6.4"
	},
	"peerDependencies": {
		"typescript": ">=5",
		"unplugin-vue-router": "^0.12.0",
		"vite-plugin-autogeneration-import-file": ">=3"
	},
	"peerDependenciesMeta": {
		"js-yaml": {
			"optional": true
		},
		"typescript": {
			"optional": true
		},
		"unplugin-vue-router": {
			"optional": true
		},
		"vite-plugin-autogeneration-import-file": {
			"optional": true
		},
		"@vueuse/integrations": {
			"optional": true
		},
		"axios": {
			"optional": true
		}
	}
}
